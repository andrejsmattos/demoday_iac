# Variáveis de Conexão EC2 - Geradas pelo Terraform
# Após executar 'terraform apply', copie os valores dos outputs para aqui

# IP público da instância EC2
EC2_HOST=<valor-do-output-instance_public_ip>

# Usuário padrão para SSH na instância
EC2_USERNAME=ec2-user

# Caminho para a chave privada SSH
# Será gerada em: iac/terraform/keys/ec2-key.pem
EC2_SSH_KEY=./keys/ec2-key.pem

# Exemplo de conexão SSH:
# ssh -i ./keys/ec2-key.pem ec2-user@<seu-ip-aqui>
